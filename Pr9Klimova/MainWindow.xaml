<Window x:Class="Pr9Klimova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pr9Klimova"
        mc:Ignorable="d"
        
        Title="Графическое приложение Климова А.И." Height="450" Width="800"
        Style="{StaticResource WindowFon}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40" />

        </Grid.RowDefinitions>



        <Frame Name="MainFrame" Grid.Row="1" HorizontalAlignment="Center" 
            Width="800" Height="344" VerticalAlignment="Bottom"
            Source="Pages/AuthPage.xaml" 
            
            NavigationUIVisibility="Hidden"
            />
        <Button Name="Back" Content="Назад" 
             HorizontalAlignment="Left" Height="20" Width="60" 
             FontSize="11pt" 
             Style="{StaticResource BigButtonBase}"
             ToolTip="Кликните для возрата на предыдущую страницу"
             Margin="2,0,0,0" Grid.Row="0"  
             Click="Back_Click"/>

        <Label Content="Разработчик: 2озИСИП-1624, Климова Алина" 
            HorizontalAlignment="Center" 
            Style="{StaticResource SmallLabel}"
            Grid.Row="2" 
            FontWeight="Bold"
            FontFamily="Book Antiqua"
            VerticalAlignment="Top"/>


    </Grid>
</Window>
