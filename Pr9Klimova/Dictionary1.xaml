<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style
            TargetType="Button" x:Key="BigButtonBase" >
        <Setter  Property="Height" Value="50"/>
        <Setter  Property="Width" Value="220"/>
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18pt"/>
        <Setter Property="Background" Value="#E0A9AF"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>

    <Style
            TargetType="Button" x:Key="BigSecondOptionButtonBase" >
        <Setter  Property="Height" Value="50"/>
        <Setter  Property="Width" Value="220"/>
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18pt"/>
        <Setter Property="Background" Value="#D1EEFC"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>

    <Style
            TargetType="Button" x:Key="BigThirdOptionButtonBase" >
        <Setter  Property="Height" Value="50"/>
        <Setter  Property="Width" Value="220"/>
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18pt"/>
        <Setter Property="Background" Value="#FFFCD6"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>

    <Style
            TargetType="Page" x:Key="PageFon">
        <Setter Property="Background" Value="#B5D5CA"/>
    </Style>

    <Style
            TargetType="Window" x:Key="WindowFon">
        <Setter Property="Background" Value="#B5D5CA"/>
    </Style>


    <Style
            TargetType="Label" x:Key="BigLabel" >
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="FontSize" Value="18pt"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>

    <Style
            TargetType="Label" x:Key="SmallLabel" >
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="FontSize" Value="14pt"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>

    <Style
            TargetType="TextBlock" x:Key="HiddenTxtBlock" >
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="Foreground" Value="Gray"/>
        <Setter Property="FontSize" Value="14pt"/>
    </Style>

    <Style
            TargetType="TextBox" >
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="18pt"/>

    </Style>

    <Style
            TargetType="PasswordBox" >
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style
            TargetType="DataGrid" >
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14pt"/>
    </Style>

    <Style
            TargetType="ComboBox" >
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="12pt"/>
    </Style>

</ResourceDictionary>