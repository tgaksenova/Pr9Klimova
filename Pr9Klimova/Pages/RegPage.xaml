<Page x:Class="Pr9Klimova.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr9Klimova.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
       Style="{StaticResource PageFon}"
      Title="Регистрация">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label Content="Введите логин" Grid.Row="0" Grid.Column="1"
       Style="{StaticResource BigLabel}"
       HorizontalAlignment="Left" VerticalAlignment="Center"
       />

        <Label Content="Введите пароль" Grid.Row="1" Grid.Column="1"
       Style="{StaticResource BigLabel}"
       HorizontalAlignment="Left" VerticalAlignment="Center"
       />

        <Label Content="Подтвердите пароль" Grid.Row="2" Grid.Column="1"
      Style="{StaticResource BigLabel}"
       HorizontalAlignment="Left" VerticalAlignment="Center"
       />



        <Label Content="Введите ФИО" Grid.Row="3" Grid.Column="1"
       Style="{StaticResource BigLabel}"
       HorizontalAlignment="Left" VerticalAlignment="Center"
       />

        <Button Name ="btnCancel" Content="Отмена" 
        Style="{StaticResource BigButtonBase}"
        ToolTip="Нажмите для отмены" 
        Height="40" Width="250"
        Grid.Column="1" Grid.Row="5" Click="btnCancel_Click" />

        <Button Name ="btnReg" Content="Регистрация" 
        Style="{StaticResource BigButtonBase}"
        ToolTip="Нажмите для входа в систему" 
        Height="40" Width="250"
        Grid.Column="2" Grid.Row="5" Click="btnReg_Click"/>



        <TextBlock Text="Логин"  Style="{StaticResource HiddenTxtBlock}"
           Height="40" Width="220" 
           Grid.Row="0" 
           Grid.Column="2"
           HorizontalAlignment="Center"
           Name="txbHintLog"
    />
        <TextBox Name ="txtlog" Text="" ToolTip="Введите логин" 
         Height="40" Width="220"
        Grid.Column="2" Grid.Row="0" HorizontalAlignment="Center"
    />

        <TextBlock Text="Пароль" Style="{StaticResource HiddenTxtBlock}"
           Height="40" Width="220" 
           Grid.Row="1" 
           Grid.Column="2"
           HorizontalAlignment="Center"
           Name="txbHintPass"
    />

        <PasswordBox Name ="pswbPass" Password="" 
             ToolTip="Введите пароль" 
        Height="40" Width="220"
        Grid.Column="2" Grid.Row="1" HorizontalAlignment="Center"
    />

        <TextBlock Text="Подтвердите пароль" Style="{StaticResource HiddenTxtBlock}"
           Height="40" Width="220"
           Grid.Row="2" 
           Grid.Column="2"
           HorizontalAlignment="Center" 
           Name="txbHintPassConfirm"
    />

        <PasswordBox Name ="pswbConfirmPass" Password="" ToolTip="Подтвердите пароль" 
        Height="40" Width="220"
        Grid.Column="2" Grid.Row="2" HorizontalAlignment="Center"
    />







        <TextBlock Text="ФИО" Style="{StaticResource HiddenTxtBlock}"
           Height="40" Width="330" 
           Grid.Row="3" 
           Grid.Column="2"
           HorizontalAlignment="Center"
           Name="txbHintFullName"
    />

        <TextBox Name ="txtFullName" Text="" ToolTip="Введите ФИО" 
         Height="40" Width="350"
        Grid.Column="2" Grid.Row="3" HorizontalAlignment="Center"
    />
    </Grid>
</Page>
