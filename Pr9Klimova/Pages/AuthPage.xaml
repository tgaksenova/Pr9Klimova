<Page x:Class="Pr9Klimova.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr9Klimova.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Style="{StaticResource PageFon}"
      Title="Авторизация">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>


        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>






        <Label Content="Логин" Grid.Row="0" Grid.Column="1"
        Style="{StaticResource BigLabel}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        />

        <Label Content="Пароль" Grid.Row="1" Grid.Column="1"
        Style="{StaticResource BigLabel}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"/>



        <TextBlock Text="Логин или почта" FontSize="18pt"
            Height="50" Width="250" 
            Grid.Row="0" Grid.Column="2"
            HorizontalAlignment="Center"
            Name="HintLog"
            Style="{StaticResource HiddenTxtBlock}"
     />
        <TextBox Name ="txtlog" Text="" 
         FontWeight="Bold" 
         ToolTip="Введите логин" 
         Height="50" Width="250"
         Grid.Column="2" Grid.Row="0"
         HorizontalAlignment="Center" 
     />
        <TextBlock Text="Пароль" FontSize="18pt"
            Height="50" Width="250" 
            Grid.Row="1" Grid.Column="2"
            HorizontalAlignment="Center"
            Style="{StaticResource HiddenTxtBlock}"
            Name="HintPass"
     />

        <PasswordBox Name ="Pass" Password="" ToolTip="Введите пароль" 
         Height="50" Width="250"
         Grid.Column="2" Grid.Row="1" HorizontalAlignment="Center"
     />

        <Button Name ="btnAuth" Content="Вход" 
         Style="{StaticResource BigButtonBase}"
         ToolTip="Нажмите для входа в систему"  
         Grid.ColumnSpan="3" Grid.Row="2" Click="btnAuth_Click"/>

        <Button Name ="btnReg" Content="Регистрация" 
         Style="{StaticResource BigButtonBase}"
         ToolTip="Нажмите для регистрации" 
         Grid.Row="3" Grid.ColumnSpan="3" Click="btnReg_Click"/>


    </Grid>
</Page>
